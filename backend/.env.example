# Copy this file to .env and fill in your API keys

# OpenWeatherMap (Phase 6)
# Get free API key at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_api_key_here

# NewsAPI (Phase 6)
# Get free API key at: https://newsapi.org
NEWSAPI_KEY=your_api_key_here

# OpenRouter (coding provider for CoderAgentSkill) — https://openrouter.ai/docs
OPENROUTER_API_KEY=your_openrouter_api_key_here

# CoderAgentSkill sandbox: comma-separated list of allowed working directories
AGENT_ALLOWED_DIRS=C:\Proyectos

# Vento (https://vento.build) — optional integration, unset by default.
# Paths in backend/src/skills/vento/client.py are inferred from the
# open-source repo and are NOT verified against a running instance.
# VENTO_BASE_URL=http://localhost:3001/api/v1
# VENTO_API_KEY=
# VENTO_MQTT_HOST=localhost
# VENTO_MQTT_PORT=1883

# Development/Deployment
FLASK_ENV=development
DEBUG=True
